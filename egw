#!/usr/bin/env python3
"""
egw — EGW writings + KJV Bible search. Zero config. One command.

  egw --search "sanctuary"     Search EGW corpus
  egw --kjv "John 3:16"        KJV verse lookup
  egw --kjv "John 3:16-18"     KJV verse range
  egw --kjv-search "faith"     KJV keyword search
  egw --kjv-chapter "John 3"   KJV full chapter
  egw --bible "John 3:16"      Find EGW quoting a verse
  egw --update                 Update to latest release
  egw --version                Show version
  egw GC 456.1                 Exact EGW paragraph lookup

KJV database builds automatically on first use (~40 min in background).
"""
__version__ = "1.1.1"
__repo__   = "gershomj/egw-tools"

import sqlite3, sys, os, re, json, subprocess, time
from pathlib import Path
from urllib.request import urlopen, Request

# ── Zero-config paths ──────────────────────────────────────
HOME    = Path(os.environ.get("EGW_HOME", os.path.expanduser("~/.egw-tools")))
HOME.mkdir(parents=True, exist_ok=True)
EGW_DB  = HOME / "egw-corpus.db"
KJV_DB  = HOME / "kjv.db"
ME      = Path(__file__).resolve()
MY_DIR  = ME.parent
BUILDER = MY_DIR / "build_kjv.py"
# Also check install directory
if not BUILDER.exists():
    alt = HOME / "build_kjv.py"
    if alt.exists():
        BUILDER = alt

ALIASES = {
    'great controversy':'GC','desire of ages':'DA','acts of the apostles':'AA',
    'patriarchs and prophets':'PP','prophets and kings':'PK','steps to christ':'SC',
    "christ's object lessons":'COL','christs object lessons':'COL',
    'ministry of healing':'MH','education':'Ed','early writings':'EW',
    'testimonies vol 1':'1T','testimonies vol 2':'2T','testimonies vol 3':'3T',
    'testimonies vol 4':'4T','testimonies vol 5':'5T','testimonies vol 6':'6T',
    'testimonies vol 7':'7T','testimonies vol 8':'8T','testimonies vol 9':'9T',
    'great controversy 1888':'GC88',
}

def nc(q): return ALIASES.get(q.strip().lower(), q.strip().upper())

def hl(text, term, ctx=80):
    idx = text.lower().find(term.lower()) if term else -1
    if idx < 0: return text[:300]
    s = max(0, idx-ctx); e = min(len(text), idx+len(term)+ctx)
    pre = '...' if s>0 else ''; post = '...' if e<len(text) else ''
    return pre + re.sub(f'(?i)({re.escape(term)})', r'**\1**', text[s:e]) + post

# ═══════════════ KJV AUTO-BUILD ═══════════════

def kjv_ensure():
    """Build KJV database in background if missing. Non-blocking."""
    if KJV_DB.exists():
        return
    
    # Resolve builder location
    builder = BUILDER
    if not builder.exists():
        # Try downloading from GitHub
        print("Downloading build_kjv.py...")
        try:
            url = f"https://raw.githubusercontent.com/{__repo__}/main/build_kjv.py"
            data = urlopen(url, timeout=30).read()
            HOME.mkdir(parents=True, exist_ok=True)
            builder = HOME / "build_kjv.py"
            builder.write_bytes(data)
            builder.chmod(0o755)
            print(f"  Downloaded to {builder}")
        except Exception as e:
            print(f"Could not download build_kjv.py: {e}")
            print("Run: curl -O https://raw.githubusercontent.com/gershomj/egw-tools/main/build_kjv.py")
            return
    
    # Start build in background
    log = HOME / "kjv-build.log"
    pidfile = HOME / "kjv-build.pid"
    
    # Check if already building
    if pidfile.exists():
        try:
            pid = int(pidfile.read_text().strip())
            os.kill(pid, 0)  # Check if alive
            print(f"KJV build already running (PID {pid})")
            print(f"  Check progress: tail -f {log}")
            return
        except (OSError, ValueError):
            pidfile.unlink(missing_ok=True)
    
    print("Building KJV database in background...")
    print(f"  This takes ~40 min. You can use EGW commands immediately.")
    print(f"  Progress: tail -f {log}")
    
    with open(log, 'w') as f:
        proc = subprocess.Popen(
            [sys.executable, str(builder)],
            stdout=f, stderr=subprocess.STDOUT,
            start_new_session=True
        )
    pidfile.write_text(str(proc.pid))

# ═══════════════ SEARCH ═══════════════

def search(conn, query, book=None, limit=30):
    safe = query.replace('"','""')
    book_f = "AND p.book_code = ?" if book else ""
    params = [book] if book else []
    cur = conn.execute(f'''
        SELECT p.book_title,p.book_code,p.page,p.paragraph,p.content,p.para_id
        FROM paragraphs_fts f JOIN paragraphs p ON f.para_id=p.para_id
        WHERE paragraphs_fts MATCH ? {book_f}
        AND p.content IS NOT NULL AND p.element_type='p'
        ORDER BY rank LIMIT ?
    ''', [f'"{safe}"'] + params + [limit])
    rows = cur.fetchall()
    if not rows:
        cur = conn.execute(f'''
            SELECT book_title,book_code,page,paragraph,content,para_id
            FROM paragraphs WHERE content LIKE ? {book_f}
            AND element_type='p' LIMIT ?
        ''', [f'%{query}%'] + params + [limit])
        rows = cur.fetchall()
    return rows

def phrase_near(conn, w1, w2, dist=10, book=None):
    rows = search(conn, w1, book, 500)
    results = []
    for title,code,page,para,content,pid in rows:
        words = content.split()
        idx1 = [i for i,w in enumerate(words) if w1.lower() in w.lower()]
        idx2 = [i for i,w in enumerate(words) if w2.lower() in w.lower()]
        for i1 in idx1:
            for i2 in idx2:
                if abs(i1-i2) <= dist:
                    results.append((title,code,page,para,content,i1,i2))
                    break
            else: continue
            break
    return results[:50]

def stats(conn, term, book=None):
    bf = "AND book_code=?" if book else ""
    params = [f'%{term}%', book] if book else [f'%{term}%']
    cur = conn.execute(f'SELECT book_code,book_title,COUNT(*) FROM paragraphs WHERE element_type="p" AND content LIKE ? {bf} GROUP BY book_code ORDER BY COUNT(*) DESC LIMIT 25', params)
    return cur.fetchall()

def concordance(conn, term, book=None):
    bf = "AND book_code=?" if book else ""
    params = [f'%{term}%', book] if book else [f'%{term}%']
    cur = conn.execute(f'SELECT book_code,page,paragraph,content FROM paragraphs WHERE element_type="p" AND content LIKE ? {bf} ORDER BY book_code,page,paragraph LIMIT 200', params)
    return cur.fetchall()

# ═══════════════ BIBLE (EGW refs) ═══════════════

def bible_lookup(conn, ref):
    ref_clean = ref.strip().replace('–','-').replace('—','-')
    cur = conn.execute('''SELECT p.book_title,p.book_code,p.page,p.paragraph,p.content,p.para_id
        FROM bible_refs br JOIN paragraphs p ON br.para_id=p.para_id
        WHERE br.ref_text LIKE ? OR br.ref_text LIKE ?
        ORDER BY p.book_title LIMIT 50''', (f'%{ref_clean}%', f'%{ref_clean.replace(" ","%")}%'))
    return cur.fetchall()

def bible_refs_in_passage(conn, code, page):
    cur = conn.execute('''SELECT page,paragraph,content,bible_refs FROM paragraphs
        WHERE book_code=? AND page=? AND element_type="p" ORDER BY paragraph''', (code,page))
    rows = cur.fetchall()
    results = []
    for p,pa,content,refs in rows:
        if refs:
            for r in json.loads(refs):
                results.append((p,pa,r,content[:200]))
    return results

def bible_stats(conn):
    cur = conn.execute('''SELECT 
        CASE 
            WHEN ref_normalized LIKE '1%' OR ref_normalized LIKE '2%' OR ref_normalized LIKE '3%'
            THEN substr(ref_normalized,1,instr(ref_normalized||' ',' ')-1) || ' ' || substr(ref_normalized,instr(ref_normalized,' ')+1,3)
            ELSE substr(ref_normalized,1,instr(ref_normalized||' ',' ')-1)
        END as book, COUNT(*) as cnt
        FROM bible_refs GROUP BY book ORDER BY cnt DESC LIMIT 30''')
    return cur.fetchall()

# ═══════════════ TOPICS ═══════════════

def topic_search(conn, query, limit=20):
    cur = conn.execute('''SELECT topic,subtopic,book_code,page,paragraph,content
        FROM topics WHERE topic LIKE ? OR subtopic LIKE ? OR content LIKE ?
        LIMIT ?''', (f'%{query}%',f'%{query}%',f'%{query}%',limit))
    return cur.fetchall()

def list_topics(conn, prefix=None):
    if prefix:
        cur = conn.execute('SELECT DISTINCT topic FROM topics WHERE topic LIKE ? ORDER BY topic', (f'{prefix}%',))
    else:
        cur = conn.execute('SELECT DISTINCT topic FROM topics ORDER BY topic LIMIT 200')
    return cur.fetchall()

# ═══════════════ REFERENCE ═══════════════

def exact(conn, code, page, para=None):
    if para:
        cur = conn.execute('SELECT book_title,page,paragraph,content FROM paragraphs WHERE book_code=? AND page=? AND paragraph=? AND element_type="p"', (code,page,para))
    else:
        cur = conn.execute('SELECT book_title,page,paragraph,content FROM paragraphs WHERE book_code=? AND page=? AND element_type="p" ORDER BY paragraph', (code,page))
    return cur.fetchall()

def chapter_lookup(conn, code, chap):
    cur = conn.execute('SELECT content FROM paragraphs WHERE book_code=? AND chapter_num=? AND element_type IN ("h1","h2","h3") LIMIT 1', (code,chap))
    h = cur.fetchone()
    cur = conn.execute('SELECT page,paragraph,content FROM paragraphs WHERE book_code=? AND chapter_num=? AND element_type="p" ORDER BY page,paragraph', (code,chap))
    return cur.fetchall(), h[0] if h else f"Chapter {chap}"

def book_diff(conn, code1, code2, page):
    rows = []
    for code in [code1, code2]:
        cur = conn.execute('SELECT book_title,page,paragraph,content FROM paragraphs WHERE book_code=? AND page=? AND element_type="p" ORDER BY paragraph', (code,page))
        rows.append((code, cur.fetchall()))
    return rows

def cite(conn, code, page, para=None):
    cur = conn.execute('SELECT book_title,page,paragraph,content,year FROM paragraphs WHERE book_code=? AND page=? AND element_type="p" LIMIT 1', (code,page))
    row = cur.fetchone()
    if not row: return None
    title, p, pa, content, year = row
    ref = f"{title}, p. {p}"
    if para: ref += f", \u00b6{para}"
    return f"{ref}.\n\n{content[:500]}..."

def person_search(conn, name):
    cur = conn.execute('''SELECT book_title,book_code,page,paragraph,content FROM paragraphs
        WHERE element_type="p" AND (content LIKE ?)
        AND (book_code LIKE "%LtMs%" OR book_code LIKE "%MR%" OR book_code LIKE "%BIO%")
        ORDER BY book_code LIMIT 30''', (f'%{name}%',))
    return cur.fetchall()

# ═══════════════ DISCOVERY ═══════════════

def book_info(conn, code):
    cur = conn.execute('SELECT * FROM book_index WHERE book_code=?', (code,))
    row = cur.fetchone()
    if not row:
        cur = conn.execute('SELECT book_code,book_title,COUNT(*),MIN(year),MAX(year) FROM paragraphs WHERE book_code=?', (code,))
        row = cur.fetchone()
    return row

def list_books(conn, filt=None):
    if filt:
        cur = conn.execute('SELECT book_code,book_title,year,paragraph_count FROM book_index WHERE book_title LIKE ? OR book_code LIKE ? ORDER BY year,book_title', (f'%{filt}%',f'%{filt}%'))
    else:
        cur = conn.execute('SELECT book_code,book_title,year,paragraph_count FROM book_index ORDER BY year,book_title')
    return cur.fetchall()

# ═══════════════ KJV BIBLE ═══════════════

def kjv_parse_ref(ref_str):
    m = re.match(r'(.+?)\s+(\d+):(\d+)(?:-(\d+))?$', ref_str.strip())
    if not m: return None
    book_name = m.group(1).strip()
    chapter = int(m.group(2)); start = int(m.group(3))
    end = int(m.group(4)) if m.group(4) else start
    BOOK_MAP = {
        'genesis':'GEN','exodus':'EXO','leviticus':'LEV','numbers':'NUM',
        'deuteronomy':'DEU','joshua':'JOS','judges':'JDG','ruth':'RUT',
        '1 samuel':'1SA','2 samuel':'2SA','1 kings':'1KI','2 kings':'2KI',
        '1 chronicles':'1CH','2 chronicles':'2CH','ezra':'EZR','nehemiah':'NEH',
        'esther':'EST','job':'JOB','psalm':'PSA','psalms':'PSA','proverbs':'PRO',
        'ecclesiastes':'ECC','song of solomon':'SNG','isaiah':'ISA','jeremiah':'JER',
        'lamentations':'LAM','ezekiel':'EZK','daniel':'DAN','hosea':'HOS',
        'joel':'JOL','amos':'AMO','obadiah':'OBA','jonah':'JON','micah':'MIC',
        'nahum':'NAM','habakkuk':'HAB','zephaniah':'ZEP','haggai':'HAG',
        'zechariah':'ZEC','malachi':'MAL',
        'matthew':'MAT','mark':'MRK','luke':'LUK','john':'JHN','acts':'ACT',
        'romans':'ROM','1 corinthians':'1CO','2 corinthians':'2CO',
        'galatians':'GAL','ephesians':'EPH','philippians':'PHP','colossians':'COL',
        '1 thessalonians':'1TH','2 thessalonians':'2TH','1 timothy':'1TI',
        '2 timothy':'2TI','titus':'TIT','philemon':'PHM','hebrews':'HEB',
        'james':'JAS','1 peter':'1PE','2 peter':'2PE','1 john':'1JN',
        '2 john':'2JN','3 john':'3JN','jude':'JUD','revelation':'REV',
    }
    abbr = BOOK_MAP.get(book_name.lower())
    return (abbr, chapter, start, end) if abbr else None

def kjv_lookup(ref_str):
    kjv_ensure()
    if not KJV_DB.exists():
        return None, "KJV database still building. Check ~/.egw-tools/kjv-build.log"
    parsed = kjv_parse_ref(ref_str)
    if not parsed: return None, f"Could not parse: {ref_str}"
    abbr, ch, start, end = parsed
    kjv = sqlite3.connect(str(KJV_DB))
    rows = kjv.execute(
        "SELECT book_name, chapter, verse, text FROM verses WHERE book_abbr=? AND chapter=? AND verse BETWEEN ? AND ? ORDER BY verse",
        (abbr, ch, start, end)).fetchall()
    kjv.close()
    ref_display = f"{rows[0][0]} {ch}:{start}" + (f"-{end}" if end > start else "") if rows else ref_str
    return rows, ref_display

def kjv_search(query, limit=30):
    kjv_ensure()
    if not KJV_DB.exists():
        return [("", 0, 0, "KJV database still building. Check progress with: egw --kjv-status", "")]
    kjv = sqlite3.connect(str(KJV_DB))
    safe = query.replace('"','""')
    rows = kjv.execute(
        "SELECT book_name, chapter, verse, text, reference FROM verses_fts WHERE verses_fts MATCH ? ORDER BY rank LIMIT ?",
        (f'"{safe}"', limit)).fetchall()
    kjv.close()
    return rows

def kjv_chapter(ref_str):
    kjv_ensure()
    if not KJV_DB.exists():
        return None, "KJV database still building. Check ~/.egw-tools/kjv-build.log"
    parsed = kjv_parse_ref(ref_str + ":1")
    if not parsed: return None, f"Could not parse: {ref_str}"
    abbr, ch, _, _ = parsed
    kjv = sqlite3.connect(str(KJV_DB))
    rows = kjv.execute(
        "SELECT book_name, chapter, verse, text FROM verses WHERE book_abbr=? AND chapter=? ORDER BY verse",
        (abbr, ch)).fetchall()
    kjv.close()
    ref_display = f"{rows[0][0]} {ch}" if rows else ref_str
    return rows, ref_display

# ═══════════════ UPDATE ═══════════════

def check_update():
    try:
        req = Request(f"https://api.github.com/repos/{__repo__}/releases/latest")
        req.add_header("Accept", "application/vnd.github+json")
        req.add_header("User-Agent", "egw-updater")
        data = json.loads(urlopen(req, timeout=10).read())
        latest = data["tag_name"].lstrip("v")
        for asset in data.get("assets", []):
            if asset["name"] == "egw":
                return latest, asset["browser_download_url"]
        return None
    except: return None

def do_update():
    result = check_update()
    if result is None:
        print("Could not check for updates."); sys.exit(1)
    latest, url = result
    if latest == __version__:
        print(f"Already up to date (v{__version__})"); return
    print(f"Updating v{__version__} → v{latest}")
    try:
        data = urlopen(url, timeout=30).read()
        backup = ME.with_suffix(".bak")
        ME.rename(backup)
        ME.write_bytes(data)
        ME.chmod(0o755)
        print(f"Updated. Old version: {backup}")
    except Exception as e:
        print(f"Update failed: {e}"); sys.exit(1)

# ═══════════════ MAIN ═══════════════

def usage():
    print(f"""egw v{__version__} — EGW + KJV Bible Search

  egw --search "sabbath"        FTS5 search EGW corpus
  egw --search "prayer" --book SC   Filter by book
  egw --kjv "John 3:16"         KJV verse lookup
  egw --kjv "John 3:16-18"      KJV verse range
  egw --kjv-search "faith hope" KJV keyword search
  egw --kjv-chapter "Psalm 23"  KJV full chapter
  egw --kjv-status              Check KJV build progress
  egw --bible "John 3:16"       Find EGW citing a verse
  egw --bible-stats             Most-quoted Bible books
  egw --stats "grace"           Term frequency by book
  egw --near "faith works" 10   Words within N words
  egw --topic "sanctuary"       Search topical index
  egw --chapter GC 41           Full chapter
  egw --diff GC GC88 456        Compare editions
  egw --cite GC 456.1           Formatted citation
  egw --person "James White"    Letters mentioning
  egw --list                    Browse all books
  egw --info GC                 Book metadata
  egw GC 456.1                  Exact paragraph lookup
  egw --update                  Update to latest release
  egw --version                 Show version

Databases: ~/.egw-tools/  (auto-created on first use)
KJV builds automatically on first --kjv command.""")

def main():
    args = sys.argv[1:]
    if not args: usage(); return

    cmd = args[0]

    # System commands
    if cmd == '--update': do_update(); return
    if cmd == '--version': print(f"egw v{__version__}"); return
    if cmd == '--help': usage(); return
    if cmd == '--kjv-status':
        log = HOME / "kjv-build.log"
        pidfile = HOME / "kjv-build.pid"
        if KJV_DB.exists():
            kjv = sqlite3.connect(str(KJV_DB))
            v = kjv.execute("SELECT COUNT(*) FROM verses").fetchone()[0]
            kjv.close()
            print(f"KJV database ready: {v:,} verses")
        elif pidfile.exists():
            try:
                pid = int(pidfile.read_text().strip())
                os.kill(pid, 0)
                print(f"KJV build running (PID {pid})")
                if log.exists():
                    print(f"Last lines of {log}:")
                    os.system(f"tail -5 {log}")
            except OSError:
                print("KJV build appears stalled. Remove ~/.egw-tools/kjv-build.pid and retry.")
        else:
            print("KJV database not built yet. Run any --kjv command to start building.")
        return

    # ══ KJV commands (no EGW DB needed) ══
    if cmd == '--kjv':
        rows, ref = kjv_lookup(args[1])
        if rows is None: print(ref)
        elif not rows: print(f"Verse not found: {ref}")
        else:
            print(f'\n{ref}\n{"─"*70}')
            for _, ch, v, text in rows:
                print(f'  [{v}] {text}')
        return

    if cmd == '--kjv-search':
        limit = 30; qparts = [args[1]] if len(args) > 1 else []; i = 2
        while i < len(args):
            if args[i] == '--limit' and i+1 < len(args):
                limit = int(args[i+1]); i += 2
            else: qparts.append(args[i]); i += 1
        query = ' '.join(qparts)
        rows = kjv_search(query, limit)
        print(f'\nKJV: "{query}" — {len(rows)} results\n{"─"*70}')
        for book, ch, v, text, ref in rows:
            print(f'  [{ref}] {text}')
        return

    if cmd == '--kjv-chapter':
        rows, ref = kjv_chapter(args[1])
        if rows is None: print(ref)
        elif not rows: print(f"Chapter not found: {ref}")
        else:
            print(f'\n{ref}\n{"─"*70}')
            for _, ch, v, text in rows:
                print(f'  [{v}] {text}')
        return

    # ══ EGW commands (need EGW DB) ══
    if not EGW_DB.exists():
        print(f"No EGW database at {EGW_DB}")
        print("Place egw-corpus.db in ~/.egw-tools/ to enable EGW search.")
        print("KJV commands (--kjv, --kjv-search, --kjv-chapter) work without it.")
        sys.exit(1)

    conn = sqlite3.connect(str(EGW_DB))

    if cmd == '--search':
        book, limit = None, 30; i = 1; qparts = []
        while i < len(args):
            if args[i] == '--book' and i+1 < len(args): book = nc(args[i+1]); i += 2
            elif args[i] == '--limit' and i+1 < len(args): limit = int(args[i+1]); i += 2
            else: qparts.append(args[i]); i += 1
        query = ' '.join(qparts)
        rows = search(conn, query, book, limit)
        b = " in " + book if book else ""
        print(f'\n"{query}"{b} — {len(rows)} results\n')
        for title,code,page,para,content,pid in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            print(f'[{code} {ref}] {title}\n  {hl(content,query.split()[0])}\n')

    elif cmd == '--near':
        words = args[1].split(); dist = 10; book = None; i = 2
        while i < len(args):
            if args[i] == '--book' and i+1 < len(args): book = nc(args[i+1]); i += 2
            else:
                try: dist = int(args[i]); i += 1
                except: i += 1
        rows = phrase_near(conn, words[0], words[1], dist, book)
        print(f'\n"{words[0]}" ~ "{words[1]}" (≤{dist}w) — {len(rows)} matches\n')
        for title,code,page,para,content,i1,i2 in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            wlist = content.split()
            s = max(0, min(i1,i2)-6); e = min(len(wlist), max(i1,i2)+7)
            snip = ' '.join(wlist[s:e])
            snip = re.sub(f'(?i)({re.escape(words[0])})', r'**\1**', snip)
            snip = re.sub(f'(?i)({re.escape(words[1])})', r'**\1**', snip)
            print(f'[{code} {ref}] ...{snip}...\n')

    elif cmd == '--stats':
        rows = stats(conn, args[1], nc(args[2]) if len(args) > 2 else None)
        print(f'\n"{args[1]}" frequency:\n')
        for code,title,cnt in rows:
            print(f'  {code:12s} {title[:45]:45s} {cnt:>5d} {"█"*min(50,cnt//2)}')

    elif cmd == '--concordance':
        book = nc(args[2]) if len(args) > 2 and args[2] != '--book' and not args[2].startswith('-') else None
        if len(args) > 3 and args[2] == '--book': book = nc(args[3])
        rows = concordance(conn, args[1], book)
        print(f'\nConcordance: "{args[1]}" — {len(rows)} occurrences\n')
        for code,page,para,content in rows:
            print(f'  {code} p{page}' + (f'.{para}' if para else '') + f': {hl(content, args[1], 50)}')

    elif cmd == '--bible':
        rows = bible_lookup(conn, args[1])
        print(f'\nEGW citing "{args[1]}" — {len(rows)} results\n')
        for title,code,page,para,content,pid in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            print(f'[{code} {ref}] {title}\n  {content[:250]}...\n')

    elif cmd == '--bible-refs':
        rows = bible_refs_in_passage(conn, nc(args[1]), int(args[2]))
        print(f'\nBible refs in {args[1]} p{args[2]}:\n')
        for p,pa,ref,ctx in rows:
            print(f'  p{p}.{pa}: {ref}')

    elif cmd == '--bible-stats':
        rows = bible_stats(conn)
