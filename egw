        parts = args[1].strip().split()
        if len(parts) >= 2 and '.' in parts[1]:
            pg, pa = (parts[1].split('.', 1) + [None])[:2]
            c = cite(conn, nc(parts[0]), int(pg), int(pa) if pa else None)
        else:
            c = cite(conn, nc(parts[0]), int(parts[1]) if len(parts) > 1 else None)
