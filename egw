def book_info(conn, code):
    cur = conn.execute('SELECT * FROM book_index WHERE book_code=?', (code,))
    row = cur.fetchone()
    if not row:
        cur = conn.execute('SELECT book_code,book_title,COUNT(*),MIN(year),MAX(year) FROM paragraphs WHERE book_code=?', (code,))
