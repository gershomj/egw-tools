        if len(parts) >= 2 and '.' in parts[1]:
            pg, pa = (parts[1].split('.', 1) + [None])[:2]
            rows = exact(conn, nc(parts[0]), int(pg), int(pa) if pa else None)
        elif len(parts) >= 2:
            try:
                pg = int(parts[1]); pa = int(parts[2]) if len(parts) > 2 else None
                rows = exact(conn, nc(parts[0]), pg, pa)
            except: rows = []
        else: rows = []
        if not rows: print('No results'); conn.close(); return
        for title,p,pa,content in rows:
