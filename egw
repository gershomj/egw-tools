def list_books(conn, filt=None):
    if filt:
        cur = conn.execute("SELECT book_code,book_title,year,paragraph_count FROM book_index WHERE book_title LIKE ? ESCAPE '\\' OR book_code LIKE ? ESCAPE '\\' ORDER BY year,book_title", (f'%{like_escape(filt)}%',f'%{like_escape(filt)}%'))
    else:
        cur = conn.execute('SELECT book_code,book_title,year,paragraph_count FROM book_index ORDER BY year,book_title')
    return cur.fetchall()

# ═══════════════ KJV BIBLE ═══════════════

def kjv_parse_ref(ref_str):
    m = re.match(r'(.+?)\s+(\d+):(\d+)(?:-(\d+))?$', ref_str.strip())
    if not m: return None
    book_name = m.group(1).strip()
    chapter = int(m.group(2)); start = int(m.group(3))
    end = int(m.group(4)) if m.group(4) else start
    BOOK_MAP = {
        'genesis':'GEN','exodus':'EXO','leviticus':'LEV','numbers':'NUM',
        'deuteronomy':'DEU','joshua':'JOS','judges':'JDG','ruth':'RUT',
        '1 samuel':'1SA','2 samuel':'2SA','1 kings':'1KI','2 kings':'2KI',
        '1 chronicles':'1CH','2 chronicles':'2CH','ezra':'EZR','nehemiah':'NEH',
        'esther':'EST','job':'JOB','psalm':'PSA','psalms':'PSA','proverbs':'PRO',
        'ecclesiastes':'ECC','song of solomon':'SNG','isaiah':'ISA','jeremiah':'JER',
        'lamentations':'LAM','ezekiel':'EZK','daniel':'DAN','hosea':'HOS',
        'joel':'JOL','amos':'AMO','obadiah':'OBA','jonah':'JON','micah':'MIC',
        'nahum':'NAM','habakkuk':'HAB','zephaniah':'ZEP','haggai':'HAG',
        'zechariah':'ZEC','malachi':'MAL',
        'matthew':'MAT','mark':'MRK','luke':'LUK','john':'JHN','acts':'ACT',
        'romans':'ROM','1 corinthians':'1CO','2 corinthians':'2CO',
        'galatians':'GAL','ephesians':'EPH','philippians':'PHP','colossians':'COL',
        '1 thessalonians':'1TH','2 thessalonians':'2TH','1 timothy':'1TI',
        '2 timothy':'2TI','titus':'TIT','philemon':'PHM','hebrews':'HEB',
        'james':'JAS','1 peter':'1PE','2 peter':'2PE','1 john':'1JN',
        '2 john':'2JN','3 john':'3JN','jude':'JUD','revelation':'REV',
    }
    abbr = BOOK_MAP.get(book_name.lower())
    return (abbr, chapter, start, end) if abbr else None

def kjv_lookup(ref_str):
    if not KJV_DB.exists():
        # Check if kjv.db exists alongside the script (bundled)
        bundled = MY_DIR / "kjv.db"
        if bundled.exists():
            import shutil
            shutil.copy2(bundled, KJV_DB)
        else:
            return None, f"KJV database not found. Reinstall or download kjv.db to {HOME}"
    parsed = kjv_parse_ref(ref_str)
    if not parsed: return None, f"Could not parse: {ref_str}"
    abbr, ch, start, end = parsed
    kjv = sqlite3.connect(str(KJV_DB))
    rows = kjv.execute(
        "SELECT book_name, chapter, verse, text FROM verses WHERE book_abbr=? AND chapter=? AND verse BETWEEN ? AND ? ORDER BY verse",
        (abbr, ch, start, end)).fetchall()
    kjv.close()
    ref_display = f"{rows[0][0]} {ch}:{start}" + (f"-{end}" if end > start else "") if rows else ref_str
    return rows, ref_display

def kjv_search(query, limit=30):
    if not KJV_DB.exists():
        bundled = MY_DIR / "kjv.db"
        if bundled.exists():
            import shutil
            shutil.copy2(bundled, KJV_DB)
        else:
            return [("", 0, 0, "", f"KJV database not found. Reinstall or download kjv.db to {HOME}")]
    kjv = sqlite3.connect(str(KJV_DB))
    safe = query.replace('"','""')
    rows = kjv.execute(
        "SELECT v.book_name, v.chapter, v.verse, v.text, v.reference FROM verses_fts fts JOIN verses v ON fts.rowid = v.id WHERE verses_fts MATCH ? ORDER BY rank LIMIT ?",
        (f'"{safe}"', limit)).fetchall()
    kjv.close()
    return rows

def kjv_chapter(ref_str):
    if not KJV_DB.exists():
        bundled = MY_DIR / "kjv.db"
        if bundled.exists():
            import shutil
            shutil.copy2(bundled, KJV_DB)
        else:
            return None, f"KJV database not found. Reinstall or download kjv.db to {HOME}"
    parsed = kjv_parse_ref(ref_str + ":1")
    if not parsed: return None, f"Could not parse: {ref_str}"
    abbr, ch, _, _ = parsed
    kjv = sqlite3.connect(str(KJV_DB))
    rows = kjv.execute(
        "SELECT book_name, chapter, verse, text FROM verses WHERE book_abbr=? AND chapter=? ORDER BY verse",
        (abbr, ch)).fetchall()
    kjv.close()
    ref_display = f"{rows[0][0]} {ch}" if rows else ref_str
    return rows, ref_display

# ═══════════════ UPDATE ═══════════════

def check_update():
    try:
        req = Request(f"https://api.github.com/repos/{__repo__}/releases/latest")
        req.add_header("Accept", "application/vnd.github+json")
        req.add_header("User-Agent", "egw-updater")
        data = json.loads(urlopen(req, timeout=10).read())
        latest = data["tag_name"].lstrip("v")
        for asset in data.get("assets", []):
            if asset["name"] == "egw":
                return latest, asset["browser_download_url"]
        return None
    except: return None

def do_update():
    result = check_update()
    if result is None:
        print("Could not check for updates."); sys.exit(1)
    latest, url = result
    if latest == __version__:
        print(f"Already up to date (v{__version__})"); return
    print(f"Updating v{__version__} → v{latest}")
    try:
        data = urlopen(url, timeout=30).read()
        backup = ME.with_suffix(".bak")
        ME.rename(backup)
        ME.write_bytes(data)
        ME.chmod(0o755)
        print(f"Updated. Old version: {backup}")
    except Exception as e:
        print(f"Update failed: {e}"); sys.exit(1)

# ═══════════════ MAIN ═══════════════

def usage():
    print(f"""egw v{__version__} — EGW + KJV Bible Search

  egw --search "sabbath"        FTS5 search EGW corpus
  egw --search "prayer" --book SC   Filter by book
  egw --kjv "John 3:16"         KJV verse lookup
  egw --kjv "John 3:16-18"      KJV verse range
  egw --kjv-search "faith hope" KJV keyword search
  egw --kjv-chapter "Psalm 23"  KJV full chapter
  egw --kjv-status              KJV database info
  egw --bible "John 3:16"       Find EGW citing a verse
  egw --bible-stats             Most-quoted Bible books
  egw --stats "grace"           Term frequency by book
  egw --near "faith works" 10   Words within N words
  egw --topic "sanctuary"       Search topical index
  egw --chapter GC 41           Full chapter
  egw --diff GC GC88 456        Compare editions
  egw --cite GC 456.1           Formatted citation
  egw --search-all "faith"      Search EGW + KJV + Strong's
  egw --strongs H1254            Strong's Hebrew/Greek lookup
  egw --person "James White"    Letters mentioning
  egw --list                    Browse all books
  egw --info GC                 Book metadata
  egw GC 456.1                  Exact paragraph lookup
  egw --egw-download            Download EGW corpus (~1.3 GB)
  egw --update                  Update to latest release
  egw --version                 Show version

Databases: ~/.egw-tools/  (auto-created on first use)
KJV database is pre-built and included in the install.
EGW corpus is downloaded on demand with --egw-download.""")

def main():
    args = sys.argv[1:]
    if not args: usage(); return

    cmd = args[0]

    # System commands (no DB needed)
    if cmd == '--update': do_update(); return
    if cmd == '--version': print(f"egw v{__version__}"); return
    if cmd == '--help': usage(); return
    if cmd == '--egw-download': egw_download(); return
    if cmd == '--kjv-status':
        if KJV_DB.exists():
            kjv = sqlite3.connect(str(KJV_DB))
            v = kjv.execute("SELECT COUNT(*) FROM verses").fetchone()[0]
            o = kjv.execute("SELECT COUNT(*) FROM verses WHERE book_abbr IN ('GEN','EXO','LEV','NUM','DEU','JOS','JDG','RUT','1SA','2SA','1KI','2KI','1CH','2CH','EZR','NEH','EST','JOB','PSA','PRO','ECC','SNG','ISA','JER','LAM','EZK','DAN','HOS','JOL','AMO','OBA','JON','MIC','NAM','HAB','ZEP','HAG','ZEC','MAL')").fetchone()[0]
            kjv.close()
            sz = KJV_DB.stat().st_size / 1e6
            print(f"KJV database: {v:,} verses, {sz:.1f} MB")
            print(f"  {o:,} OT, {v-o:,} NT")
        else:
            print("KJV database not found.")
            print(f"Expected at: {KJV_DB}")
            print("Reinstall from: https://github.com/gershomj/egw-tools")
        return

    # ══ KJV commands (no EGW DB needed) ══
    if cmd == '--kjv':
        rows, ref = kjv_lookup(args[1])
        if rows is None: print(ref)
        elif not rows: print(f"Verse not found: {ref}")
        else:
            print(f'\n{ref}\n{"─"*70}')
            for _, ch, v, text in rows:
                print(f'  [{v}] {text}')
        return

    if cmd == '--kjv-search':
        limit = 30; qparts = [args[1]] if len(args) > 1 else []; i = 2
        while i < len(args):
            if args[i] == '--limit' and i+1 < len(args):
                limit = int(args[i+1]); i += 2
            else: qparts.append(args[i]); i += 1
        query = ' '.join(qparts)
        rows = kjv_search(query, limit)
        print(f'\nKJV: "{query}" — {len(rows)} results\n{"─"*70}')
        for book, ch, v, text, ref in rows:
            print(f'  [{ref}] {text}')
        return

    if cmd == '--kjv-chapter':
        rows, ref = kjv_chapter(args[1])
        if rows is None: print(ref)
        elif not rows: print(f"Chapter not found: {ref}")
        else:
            print(f'\n{ref}\n{"─"*70}')
            for _, ch, v, text in rows:
                print(f'  [{v}] {text}')
        return

    # ══ EGW commands (need EGW DB) ══
    if not egw_ensure():
        sys.exit(1)

    conn = sqlite3.connect(str(EGW_DB))

    if cmd == '--search':
        book, limit = None, 30; i = 1; qparts = []
        while i < len(args):
            if args[i] == '--book' and i+1 < len(args): book = nc(args[i+1]); i += 2
            elif args[i] == '--limit' and i+1 < len(args): limit = int(args[i+1]); i += 2
            else: qparts.append(args[i]); i += 1
        query = ' '.join(qparts)
        rows = search(conn, query, book, limit)
        b = " in " + book if book else ""
        print(f'\n"{query}"{b} — {len(rows)} results\n')
        for title,code,page,para,content,pid in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            print(f'[{code} {ref}] {title}\n  {hl(content,query.split()[0])}\n')

    elif cmd == '--near':
        words = args[1].split(); dist = 10; book = None; i = 2
        while i < len(args):
            if args[i] == '--book' and i+1 < len(args): book = nc(args[i+1]); i += 2
            else:
                try: dist = int(args[i]); i += 1
                except: i += 1
        rows = phrase_near(conn, words[0], words[1], dist, book)
        print(f'\n"{words[0]}" ~ "{words[1]}" (≤{dist}w) — {len(rows)} matches\n')
        for title,code,page,para,content,i1,i2 in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            wlist = content.split()
            s = max(0, min(i1,i2)-6); e = min(len(wlist), max(i1,i2)+7)
            snip = ' '.join(wlist[s:e])
            snip = re.sub(f'(?i)({re.escape(words[0])})', r'**\1**', snip)
            snip = re.sub(f'(?i)({re.escape(words[1])})', r'**\1**', snip)
            if s>0: snip = '...' + snip
            if e<len(wlist): snip = snip + '...'
            print(f'[{code} {ref}] {title}\n  {snip}\n')

    elif cmd == '--stats':
        query = args[1]; book = None
        if len(args) > 2 and args[2] == '--book': book = nc(args[3])
        rows = stats(conn, query, book)
        maxc = max(r[2] for r in rows) if rows else 1
        print(f'\n"{query}" frequency:\n')
        for code,title,cnt in rows:
            bar = '█' * int(60 * cnt / maxc)
            print(f'  {code:12s} {title:50s} {cnt:5d} {bar}')

    elif cmd == '--concordance':
        query = args[1]; book = None
        if len(args) > 2 and args[2] == '--book': book = nc(args[3])
        rows = concordance(conn, query, book)
        print(f'\nConcordance: "{query}" — {len(rows)} results\n')
        for code,page,para,content in rows:
            print(f'[{code} p{page}.{para or "?"}] {hl(content,query)[:200]}')

    elif cmd == '--bible':
        rows = bible_lookup(conn, args[1])
        print(f'\nEGW citing "{args[1]}" — {len(rows)} results\n{"─"*70}')
        for title,code,page,para,content,pid in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            print(f'[{code} {ref}] {title}\n  {hl(content,args[1])[:250]}\n')

    elif cmd == '--bible-refs':
        ref_rows = bible_refs_in_passage(conn, nc(args[1]), int(args[2]))
        print(f'\nBible refs in {args[1]} p{args[2]}:\n')
        for page,para,ref,ctx in ref_rows:
            print(f'  {ref:<20s} — {ctx[:120]}...')


    elif cmd == '--search-all':
        query = ' '.join(args[1:]) if len(args) > 1 else ''
        if not query:
            print("Usage: egw --search-all <query>")
        else:
            # Search EGW + KJV + Strong's
            # EGW results
            egw_rows = search(conn, query, None, 10)
            # KJV results  
            kjv_rows = kjv_search(query, 10)
            # Strong's
            strongs_rows = []
            strongs_db = os.path.expanduser("~/.hermes/strongs.db")
            if os.path.exists(strongs_db):
                sconn = sqlite3.connect(strongs_db)
                for table in ['hebrew', 'greek']:
                    srows = sconn.execute(f"SELECT '{table}', strongs_id, lemma, kjv_def FROM {table} WHERE kjv_def LIKE ? OR lemma LIKE ? LIMIT 5", 
                        (f'%{query}%', f'%{query}%')).fetchall()
                    strongs_rows.extend(srows)
                sconn.close()
            
            print(f'\nUnified search: "{query}"\n{"="*70}')
            if egw_rows:
                print('\n── EGW Writings ──')
                for title,code,page,para,content,pid in egw_rows[:5]:
                    ref = f'p{page}.{para}'
                    print(f'[{code} {ref}] {title}\n  {content[:200]}...\n')
            if kjv_rows:
                print('\n── KJV Bible ──')
                for book,ch,v,text,ref in kjv_rows[:5]:
                    print(f'[{ref}] {text[:200]}')
            if strongs_rows:
                print('\n── Strong\'s ──')
                for src,sid,lemma,defn in strongs_rows[:5]:
                    print(f'[{src} {sid}] {lemma}: {defn[:150]}')
            if not egw_rows and not kjv_rows and not strongs_rows:
                print(f'No results for "{query}"')

    elif cmd == '--strongs':
        strongs_db = os.path.expanduser("~/.hermes/strongs.db")
        if not os.path.exists(strongs_db):
            print("Strong's database not found.")
        else:
            ref = args[1] if len(args) > 1 else ''
            sconn = sqlite3.connect(strongs_db)
            table = 'hebrew' if ref.upper().startswith('H') else 'greek'
            row = sconn.execute(f"SELECT * FROM {table} WHERE strongs_id=?", (ref.upper(),)).fetchone()
            if row:
                print(f'\n{row[0]}: {row[1]}')
                if row[2]: print(f'  Transliteration: {row[2]}')
                if row[3]: print(f'  Pronunciation: {row[3]}')
                if row[4]: print(f'  Derivation: {row[4]}')
                if row[5]: print(f'  Definition: {row[5]}')
                if row[6]: print(f'  KJV usage: {row[6]}')
            else:
                print(f"Strong's number not found: {ref}")
            sconn.close()

    elif cmd == '--bible-stats':
        rows = bible_stats(conn)
        print('\nMost-quoted Bible books:\n')
        for book,cnt in rows:
            print(f'  {book:<20s} {cnt:5d}')

    elif cmd == '--topic':
        rows = topic_search(conn, args[1])
        print(f'\nTopics: "{args[1]}" — {len(rows)} results\n')
        for topic,subtopic,code,page,para,content in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            print(f'[{code} {ref}] {topic} / {subtopic}\n  {content[:200]}...\n')

    elif cmd == '--topics':
        prefix = args[1] if len(args) > 1 else None
        rows = list_topics(conn, prefix)
        for r in rows: print(r[0])

    elif cmd == '--chapter':
        rows, heading = chapter_lookup(conn, nc(args[1]), int(args[2]))
        print(f'\n{heading}\n{"─"*70}')
        for page,para,content in rows:
            print(f'  {content}\n')

    elif cmd == '--diff':
        rows = book_diff(conn, nc(args[1]), nc(args[2]), int(args[3]))
        for code,verses in rows:
            print(f'\n--- {code} ---')
            for _,p,pa,content in verses[:5]:
                print(f'  [{p}.{pa or "?"}] {content[:200]}...')

    elif cmd == '--cite':
        # Accept both "GC 456.1" (two args) and "GC.456.1" (one arg)
        if len(args) >= 3:
            code = nc(args[1])
            ref = args[2]
        elif len(args) >= 2:
            parts = args[1].split()
            if len(parts) >= 2:
                code = nc(parts[0])
                ref = parts[1]
            else:
                code = nc(args[1])
                ref = None
        else:
            print("Usage: egw --cite GC 456.1"); return
        if ref:
            ref_parts = ref.split('.')
            page = int(ref_parts[0])
            para = int(ref_parts[1]) if len(ref_parts) > 1 else None
            result = cite(conn, code, page, para)
            if result: print(result)
            else: print(f"Not found: {code} {ref}")
        else:
            print(f"Usage: egw --cite GC 456.1")

    elif cmd == '--person':
        rows = person_search(conn, args[1])
        print(f'\nLetters mentioning "{args[1]}" — {len(rows)} results\n')
        for title,code,page,para,content in rows:
            print(f'[{code} p{page}.{para or "?"}] {title}\n  {content[:250]}...\n')

    elif cmd == '--list':
        rows = list_books(conn, args[1] if len(args) > 1 else None)
        for code,title,year,count in rows:
            print(f'{code:<12s} {title:<50s} {count:>6,}')

    elif cmd == '--info':
        row = book_info(conn, nc(args[1]))
        if row:
            if len(row) >= 4:
                print(f'{row[0]}: {row[1]}')
                print(f'  Year: {row[2]}')
                print(f'  Category: {row[3]}')
                if len(row) >= 5: print(f'  Paragraphs: {row[4]:,}')
            else:
                print(f'{row[0]}: {row[1]}')
                print(f'  Paragraphs: {row[2]:,}')
        else:
            print(f"Book not found: {args[1]}")

    # ══ EGW paragraph reference (e.g. "GC 456.1" or "GC 456") ══
    elif re.match(r'^[A-Za-z0-9]+$', cmd) and len(args) >= 2:
        code = nc(cmd)
        ref = args[1].split('.')
        page = int(ref[0])
        para = int(ref[1]) if len(ref) > 1 else None
        rows = exact(conn, code, page, para)
        if rows:
            if para:
                for title,p,pa,content in rows:
                    print(f'\n{"="*70}\n{title}\nPage {p}, Paragraph {pa}\n{"="*70}\n{content}')
            else:
                for title,p,pa,content in rows:
                    print(f'\n[{pa}] {content}')
        else:
            print(f"Not found: {code} {args[1]}")

    # ══ Unknown command → try as EGW reference ══
    else:
        print(f"Unknown command: {cmd}")
        print("Run 'egw --help' for usage.")
        sys.exit(1)

    conn.close()

