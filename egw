#!/usr/bin/env python3
"""
egw — EGW writings + KJV Bible search. Zero config. One command.

  egw --search "sanctuary"     Search EGW corpus
  egw --kjv "John 3:16"        KJV verse lookup
  egw --kjv "John 3:16-18"     KJV verse range
  egw --kjv-search "faith"     KJV keyword search
  egw --kjv-chapter "John 3"   KJV full chapter
  egw --bible "John 3:16"      Find EGW quoting a verse
  egw --update                 Update to latest release
  egw --version                Show version
  egw GC 456.1                 Exact EGW paragraph lookup

KJV database is pre-built and included. EGW corpus downloaded on demand.
"""
__version__ = "2.0.1"
__repo__   = "gershomj/egw-tools"

import sqlite3, sys, os, re, json, subprocess, time
from pathlib import Path
from urllib.request import urlopen, Request

# ── Zero-config paths ──────────────────────────────────────
HOME    = Path(os.environ.get("EGW_HOME", os.path.expanduser("~/.egw-tools")))
HOME.mkdir(parents=True, exist_ok=True)
EGW_DB  = HOME / "egw-corpus.db"
KJV_DB  = HOME / "kjv.db"
ME      = Path(__file__).resolve()
MY_DIR  = ME.parent

ALIASES = {
    'great controversy':'GC','desire of ages':'DA','acts of the apostles':'AA',
    'patriarchs and prophets':'PP','prophets and kings':'PK','steps to christ':'SC',
    "christ's object lessons":'COL','christs object lessons':'COL',
    'ministry of healing':'MH','education':'Ed','early writings':'EW',
    'testimonies vol 1':'1T','testimonies vol 2':'2T','testimonies vol 3':'3T',
    'testimonies vol 4':'4T','testimonies vol 5':'5T','testimonies vol 6':'6T',
    'testimonies vol 7':'7T','testimonies vol 8':'8T','testimonies vol 9':'9T',
    'great controversy 1888':'GC88',
}

def nc(q): return ALIASES.get(q.strip().lower(), q.strip().upper())

def hl(text, term, ctx=80):
    idx = text.lower().find(term.lower()) if term else -1
    if idx < 0: return text[:300]
    s = max(0, idx-ctx); e = min(len(text), idx+len(term)+ctx)
    pre = '...' if s>0 else ''; post = '...' if e<len(text) else ''
    return pre + re.sub(f'(?i)({re.escape(term)})', r'**\1**', text[s:e]) + post

def like_escape(s):
    """Escape SQLite LIKE wildcards % and _ in user input."""
    return s.replace('\\', '\\\\').replace('%', '\\%').replace('_', '\\_')

# ═══════════════ EGW CORPUS DOWNLOAD ═══════════════

def egw_download():
    """Download EGW corpus from GitHub Releases. ~1.3 GB."""
    if EGW_DB.exists():
        print(f"EGW corpus already exists at {EGW_DB}")
        sz = EGW_DB.stat().st_size / 1e9
        print(f"  Size: {sz:.1f} GB")
        return

    print("EGW corpus (~1.3 GB) will be downloaded from GitHub Releases.")
    print(f"  Destination: {EGW_DB}")
    print()
    try:
        resp = input("Continue? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\nCancelled.")
        return

    if resp not in ('y', 'yes'):
        print("Skipped. Place egw-corpus.db in ~/.egw-tools/ manually.")
        return

    # Find the asset URL
    try:
        req = Request(f"https://api.github.com/repos/{__repo__}/releases/latest")
        req.add_header("Accept", "application/vnd.github+json")
        req.add_header("User-Agent", "egw-downloader")
        data = json.loads(urlopen(req, timeout=10).read())
    except Exception as e:
        print(f"Could not check GitHub for EGW corpus: {e}")
        print("Download manually: https://github.com/gershomj/egw-tools/releases")
        return

    asset_url = None
    for asset in data.get("assets", []):
        if asset["name"] == "egw-corpus.db":
            asset_url = asset["browser_download_url"]
            break

    if not asset_url:
        print("EGW corpus not found in latest release assets.")
        print("Download manually: https://github.com/gershomj/egw-tools/releases")
        return

    # Download with progress
    print(f"Downloading...")
    try:
        # Stream download
        import shutil
        with urlopen(asset_url, timeout=600) as response:
            total = int(response.headers.get('content-length', 0))
            downloaded = 0
            chunk_size = 8192 * 128  # 1 MB chunks
            with open(EGW_DB, 'wb') as f:
                while True:
                    chunk = response.read(chunk_size)
                    if not chunk:
                        break
                    f.write(chunk)
                    downloaded += len(chunk)
                    if total:
                        pct = downloaded / total * 100
                        mb = downloaded / 1e6
                        total_mb = total / 1e6
                        print(f"\r  {pct:.0f}%  {mb:.0f}/{total_mb:.0f} MB", end='', flush=True)
            print()
        print("Done.")
        # Quick integrity check (avoids full scan)
        try:
            db = sqlite3.connect(str(EGW_DB))
            ok = db.execute("PRAGMA quick_check").fetchone()[0]
            db.close()
            if ok != "ok":
                print(f"  Warning: database may be corrupted ({ok}). Try re-downloading.")
            else:
                print(f"  Verified: {EGW_DB}")
                print(f"  Run 'egw --search \"sabbath\"' to test.")
        except sqlite3.Error as e:
            print(f"  Warning: {e}")
    except Exception as e:
        EGW_DB.unlink(missing_ok=True)
        print(f"\nDownload failed: {e}")
        print("Try again with: egw --egw-download")

def egw_ensure():
    """Ensure EGW database exists. Prompt to download if missing."""
    if EGW_DB.exists():
        return True

    print(f"No EGW database at {EGW_DB}")
    print("The EGW corpus is a separate 1.3 GB download (optional).")
    try:
        resp = input("Download it now? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\nSkipped. KJV commands work without it.")
        return False

    if resp in ('y', 'yes'):
        egw_download()
        return EGW_DB.exists()
    else:
        print("KJV commands (--kjv, --kjv-search, --kjv-chapter) work without it.")
        return False

# ═══════════════ SEARCH ═══════════════

def search(conn, query, book=None, limit=30):
    safe = query.replace('"','""')
    book_f = "AND p.book_code = ?" if book else ""
    params = [book] if book else []
    cur = conn.execute(f'''
        SELECT p.book_title,p.book_code,p.page,p.paragraph,p.content,p.para_id
        FROM paragraphs_fts f JOIN paragraphs p ON f.para_id=p.para_id
        WHERE paragraphs_fts MATCH ? {book_f}
        AND p.content IS NOT NULL AND p.element_type='p'
        ORDER BY rank LIMIT ?
    ''', [f'"{safe}"'] + params + [limit])
    rows = cur.fetchall()
    if not rows:
        cur = conn.execute(f'''
            SELECT book_title,book_code,page,paragraph,content,para_id
            FROM paragraphs WHERE content LIKE ? ESCAPE '\\' {book_f}
            AND element_type='p' LIMIT ?
        ''', [f'%{like_escape(query)}%'] + params + [limit])
        rows = cur.fetchall()
    return rows

def phrase_near(conn, w1, w2, dist=10, book=None):
    rows = search(conn, w1, book, 500)
    results = []
    for title,code,page,para,content,pid in rows:
        words = content.split()
        idx1 = [i for i,w in enumerate(words) if w1.lower() in w.lower()]
        idx2 = [i for i,w in enumerate(words) if w2.lower() in w.lower()]
        for i1 in idx1:
            for i2 in idx2:
                if abs(i1-i2) <= dist:
                    results.append((title,code,page,para,content,i1,i2))
                    break
            else: continue
            break
    return results[:50]

def stats(conn, term, book=None):
    bf = "AND book_code=?" if book else ""
    params = [f'%{like_escape(term)}%', book] if book else [f'%{like_escape(term)}%']
    cur = conn.execute(f'SELECT book_code,book_title,COUNT(*) FROM paragraphs WHERE element_type="p" AND content LIKE ? ESCAPE \'\\\' {bf} GROUP BY book_code ORDER BY COUNT(*) DESC LIMIT 25', params)
    return cur.fetchall()

def concordance(conn, term, book=None):
    bf = "AND book_code=?" if book else ""
    params = [f'%{like_escape(term)}%', book] if book else [f'%{like_escape(term)}%']
    cur = conn.execute(f'SELECT book_code,page,paragraph,content FROM paragraphs WHERE element_type="p" AND content LIKE ? ESCAPE \'\\\' {bf} ORDER BY book_code,page,paragraph LIMIT 200', params)
    return cur.fetchall()

# ═══════════════ BIBLE (EGW refs) ═══════════════

def bible_lookup(conn, ref):
    ref_clean = ref.strip().replace('–','-').replace('—','-')
    cur = conn.execute('''SELECT p.book_title,p.book_code,p.page,p.paragraph,p.content,p.para_id
        FROM bible_refs br JOIN paragraphs p ON br.para_id=p.para_id
        WHERE br.ref_text LIKE ? ESCAPE '\\' OR br.ref_text LIKE ? ESCAPE '\\'
        ORDER BY p.book_title LIMIT 50''', (f'%{like_escape(ref_clean)}%', f'%{like_escape(ref_clean.replace(" ","%"))}%'))
    return cur.fetchall()

def bible_refs_in_passage(conn, code, page):
    cur = conn.execute('''SELECT page,paragraph,content,bible_refs FROM paragraphs
        WHERE book_code=? AND page=? AND element_type="p" ORDER BY paragraph''', (code,page))
    rows = cur.fetchall()
    results = []
    for p,pa,content,refs in rows:
        if refs:
            for r in json.loads(refs):
                results.append((p,pa,r,content[:200]))
    return results

def bible_stats(conn):
    cur = conn.execute('''SELECT 
        CASE 
            WHEN ref_normalized LIKE '1%' OR ref_normalized LIKE '2%' OR ref_normalized LIKE '3%'
            THEN substr(ref_normalized,1,instr(ref_normalized||' ',' ')-1) || ' ' || substr(ref_normalized,instr(ref_normalized,' ')+1,3)
            ELSE substr(ref_normalized,1,instr(ref_normalized||' ',' ')-1)
        END as book, COUNT(*) as cnt
        FROM bible_refs GROUP BY book ORDER BY cnt DESC LIMIT 30''')
    return cur.fetchall()

# ═══════════════ TOPICS ═══════════════

def topic_search(conn, query, limit=20):
    cur = conn.execute('''SELECT topic,subtopic,book_code,page,paragraph,content
        FROM topics WHERE topic LIKE ? ESCAPE '\\' OR subtopic LIKE ? ESCAPE '\\' OR content LIKE ? ESCAPE '\\'
        LIMIT ?''', (f'%{like_escape(query)}%',f'%{like_escape(query)}%',f'%{like_escape(query)}%',limit))
    return cur.fetchall()

def list_topics(conn, prefix=None):
    if prefix:
        cur = conn.execute("SELECT DISTINCT topic FROM topics WHERE topic LIKE ? ESCAPE '\\' ORDER BY topic", (f'{like_escape(prefix)}%',))
    else:
        cur = conn.execute('SELECT DISTINCT topic FROM topics ORDER BY topic LIMIT 200')
    return cur.fetchall()

# ═══════════════ REFERENCE ═══════════════

def exact(conn, code, page, para=None):
    if para:
        cur = conn.execute('SELECT book_title,page,paragraph,content FROM paragraphs WHERE book_code=? AND page=? AND paragraph=? AND element_type="p"', (code,page,para))
    else:
        cur = conn.execute('SELECT book_title,page,paragraph,content FROM paragraphs WHERE book_code=? AND page=? AND element_type="p" ORDER BY paragraph', (code,page))
    return cur.fetchall()

def chapter_lookup(conn, code, chap):
    cur = conn.execute('SELECT content FROM paragraphs WHERE book_code=? AND chapter_num=? AND element_type IN ("h1","h2","h3") LIMIT 1', (code,chap))
    h = cur.fetchone()
    cur = conn.execute('SELECT page,paragraph,content FROM paragraphs WHERE book_code=? AND chapter_num=? AND element_type="p" ORDER BY page,paragraph', (code,chap))
    return cur.fetchall(), h[0] if h else f"Chapter {chap}"

def book_diff(conn, code1, code2, page):
    rows = []
    for code in [code1, code2]:
        cur = conn.execute('SELECT book_title,page,paragraph,content FROM paragraphs WHERE book_code=? AND page=? AND element_type="p" ORDER BY paragraph', (code,page))
        rows.append((code, cur.fetchall()))
    return rows

def cite(conn, code, page, para=None):
    cur = conn.execute('SELECT book_title,page,paragraph,content,year FROM paragraphs WHERE book_code=? AND page=? AND element_type="p" LIMIT 1', (code,page))
    row = cur.fetchone()
    if not row: return None
    title, p, pa, content, year = row
    ref = f"{title}, p. {p}"
    if para: ref += f", \u00b6{para}"
    return f"{ref}.\n\n{content[:500]}..."

def person_search(conn, name):
    cur = conn.execute('''SELECT book_title,book_code,page,paragraph,content FROM paragraphs
        WHERE element_type="p" AND (content LIKE ? ESCAPE '\\')
        AND (book_code LIKE "%LtMs%" OR book_code LIKE "%MR%" OR book_code LIKE "%BIO%")
        ORDER BY book_code LIMIT 30''', (f'%{like_escape(name)}%',))
    return cur.fetchall()

