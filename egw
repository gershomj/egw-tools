    elif cmd == '--person':
        rows = person_search(conn, args[1])
        print(f'\n"{args[1]}" in letters/manuscripts — {len(rows)} results\n')
        for title,code,page,para,content in rows:
            ref = f'p{page}' + (f'.{para}' if para else '')
            print(f'[{code} {ref}] {title}\n  {content[:250]}...\n')

    elif cmd == '--info':
        row = book_info(conn, nc(args[1]))
        if row:
            print(f'{row[0]}: {row[1]}\n  Year: {row[2]}\n  Category: {row[3]}\n  Paragraphs: {row[4]:,}')

    elif cmd == '--chapter':
        rows, heading = chapter_lookup(conn, nc(args[1]), int(args[2]))
        title = rows[0][0] if rows else '?'
        print(f'\n{"="*70}\n{title}\n{heading}\n{"="*70}')
        for p,pa,content in rows:
            if p is not None:
                print(f'\n**[p{p}' + (f'.{pa}' if pa else '') + f']** {content}')

    elif cmd == '--list':
